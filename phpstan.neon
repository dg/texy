parameters:
	level: 7

	paths:
		- src

	excludePaths:
		- src/Texy.php  # compatibility file with if (false) block

	checkMissingCallableSignature: true

	ignoreErrors:
		# Runtime type validation for generic arrays in Node constructors.
		# PHP lacks native generic arrays, so we use: (fn(Foo ...$x) {})(...$items)
		# to validate that all items are of type Foo. The result is intentionally unused.
		-
			identifier: expr.resultUnused
			paths:
				- src/Texy/Nodes/

		# Empty generator pattern using `false && yield` to satisfy return type Generator
		# while yielding nothing. PHPStan correctly sees issues with this pattern.
		-
			identifier: booleanAnd.leftAlwaysFalse
			path: src/Texy/Node.php
		-
			identifier: generator.valueType
			path: src/Texy/Node.php

		# Regex capture groups return null when not matched, ?? handles this correctly.
		# PHPStan sees variable as "always existing" from list() assignment.
		-
			identifier: nullCoalesce.variable
			paths:
				- src/Texy/Modules/BlockQuoteModule.php
				- src/Texy/Modules/ListModule.php

		# Runtime validation of array items using array_filter. PHPStan sees the filter
		# as unnecessary because typed arrays can't contain falsy values, but this
		# validates runtime data that may not match the declared types.
		-
			identifier: arrayFilter.same
			paths:
				- src/Texy/Nodes/

includes:
	- phpstan-baseline.neon
